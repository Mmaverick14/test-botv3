# Discord Bot Configuration - FiveM Faction Bot
# Kopíruj do .env.local (Vercel environment variables)

# =================================
# DISCORD API SETTINGS
# =================================

# Tvůj Discord Bot Token (z Discord Developer Portal)
DISCORD_TOKEN=tvuj_bot_token_zde

# Tvůj Discord Public Key (z Discord Developer Portal)
DISCORD_PUBLIC_KEY=tvuj_public_key_zde

# ID tvého Discord serveru (Guild ID)
GUILD_ID=1234567890123456789

# =================================
# CHANNEL IDS - Důležité kanály
# =================================

# Kanál pro rádiový systém
CHANNEL_ID_RADIO=1234567890123456789

# Tajný kanál pro vedení (anonymní zprávy)
VEDENI_CHANNEL_ID=1234567890123456789

# Nouzový kanál pro PANIC systém
PANIC_CHANNEL_ID=1234567890123456789

# Kanál pro logování všech akcí
LOGS_CHANNEL_ID=1234567890123456789

# Kanál pro plánování akcí
AKCE_CHANNEL_ID=1234567890123456789

# =================================
# ROLE IDS - Role ve serveru
# =================================

# Role "PANIC" - pro únosy
PANIC_ROLE_ID=1234567890123456789

# Role "Vedení" - pro vedoucí členy
VEDENI_ROLE_ID=1234567890123456789

# =================================
# VERCEL KV (Redis) - Database
# =================================

# Tyto proměnné jsou automaticky nastaveny Vercelом
# Pokud jsi na lokálním prostředí:
# KV_URL=redis://localhost:6379
# KV_REST_API_URL=http://localhost:8079
# KV_REST_API_TOKEN=tvuj_token

# =================================
# APLIKAČNÍ NASTAVENÍ
# =================================

# Vývojový režim (true/false)
DEV_MODE=false

# URL pro Discord interactions webhook
DISCORD_WEBHOOK_URL=https://tvoj-bot.vercel.app/api/interactions

# =================================
# TIPS PRO NASTAVENÍ
# =================================

# 1. Vytvoř novou aplikaci na https://discord.com/developers/applications
# 2. Nastavíš Interactions Endpoint URL: https://tvoj-bot.vercel.app/api/interactions
# 3. Zkopíruj Bot Token a Public Key do .env.local
# 4. Vytvoř kanály a role na svém serveru, jejich ID dej do .env
# 5. Deploy na Vercel a testuj bot

# POZNÁMKA: NIKDY nesdílej svůj DISCORD_TOKEN nebo PUBLIC_KEY!
